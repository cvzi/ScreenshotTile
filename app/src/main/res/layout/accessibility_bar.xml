<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/linearLayoutOuter"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="0dp">

    <LinearLayout
        android:id="@+id/rowFloatingButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/buttonScreenshot"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/take_screenshot"
            android:src="@drawable/ic_black_dot_animate_shutter" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/longScreenshotPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="#CC111111"
        android:orientation="vertical"
        android:padding="6dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/textLongScreenshotStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="220dp"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            tools:text="Scroll manually, then tap Capture" />

        <TextView
            android:id="@+id/textLongScreenshotCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="6dp"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            tools:text="Captured: 2" />

        <ProgressBar
            android:id="@+id/progressLongScreenshot"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:indeterminate="true"
            android:visibility="gone"
            tools:visibility="visible" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonLongScreenshotCapture"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="@string/long_screenshot_capture_next"
                android:textSize="12sp" />

            <Button
                android:id="@+id/buttonLongScreenshotDone"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:minWidth="0dp"
                android:text="@string/long_screenshot_done"
                android:textSize="12sp" />

            <Button
                android:id="@+id/buttonLongScreenshotCancel"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:minWidth="0dp"
                android:text="@string/long_screenshot_cancel"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
